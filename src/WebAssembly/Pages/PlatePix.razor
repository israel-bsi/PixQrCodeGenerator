@page "/"
@using Net.Codecrete.QrCodeGenerator
@using WebAssembly.Domain
@using WebAssembly.Domain.Requests
@using WebAssembly.Services
@inject IPixService PixService
@inject IJSRuntime JS

<div class="container-fluid py-5">
    <div class="row">
        <div class="col-md-5 mb-4">
            <div class="card shadow-sm border-0 p-4">
                <h3 class="fw-bold mb-4">Configurar Placa</h3>
                <div class="mb-3">
                    <label class="form-label">Tipo de Chave</label>
                    <select class="form-select" @bind="Request.KeyType" @bind:after="GenerateQrCode">
                        <option value="@EKeyType.Document">CPF/CNPJ</option>
                        <option value="@EKeyType.Email">E-mail</option>
                        <option value="@EKeyType.PhoneNumber">Telefone</option>
                        <option value="@EKeyType.Random">Chave Aleatória</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Chave Pix</label>
                    <input class="form-control" placeholder="Digite sua chave" @bind="Request.Key" @bind:event="oninput" @bind:after="GenerateQrCode" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Nome do Recebedor</label>
                    <input class="form-control" placeholder="Ex: João Silva" @bind="Request.Name" @bind:event="oninput" @bind:after="GenerateQrCode" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Cidade</label>
                    <input class="form-control" placeholder="Ex: Sao Paulo" @bind="Request.City" @bind:event="oninput" @bind:after="GenerateQrCode" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Valor (Opcional)</label>
                    <input type="number" class="form-control" @bind="Request.Value" @bind:event="oninput" @bind:after="GenerateQrCode" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Identificador (TxId - Opcional)</label>
                    <input class="form-control" placeholder="Ex: MESA01" @bind="Request.TxId" @bind:event="oninput" @bind:after="GenerateQrCode" />
                    <small class="text-muted" style="font-size: 0.75rem;">Máx. 25 caracteres alfanuméricos. Espaços serão removidos.</small>
                </div>
                <button class="btn btn-primary w-100 mt-3 py-2 fw-bold" @onclick="DownloadPlate">
                    <i class="bi bi-download me-2"></i> Baixar Placa em PNG
                </button>
            </div>
        </div>

        <div class="col-md-7 d-flex justify-content-center align-items-start">
            <div id="placa-pix" class="pix-card">
                <div class="pix-header">
                    <span>Pague com</span>
                    <img src="pix-logo.png" alt="Logo Pix" class="pix-logo-img">
                </div>

                <div class="qr-container">
                    <div class="qr-code-white-box">
                        <img src="@qrCodeBase64" alt="QR Code" />
                    </div>
                </div>

                <div class="pix-footer">
                    <div class="info-group">
                        <span class="label">Chave Pix:</span>
                        <div class="pill">@Request.Key</div>
                    </div>
                    <div class="info-group mt-3">
                        <span class="label">Nome:</span>
                        <div class="pill">@Request.Name</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private CreatePixPlateRequest Request { get; } = new()
    {
        KeyType = EKeyType.Document,
        Key = "000.000.000-00",
        Name = "NOME DO RECEBEDOR",
        City = "CIDADE"
    };

    private string qrCodeBase64 = "";

    protected override void OnInitialized() => GenerateQrCode();

    private void GenerateQrCode()
    {
        if (string.IsNullOrWhiteSpace(Request.Key) || string.IsNullOrWhiteSpace(Request.Name) || string.IsNullOrWhiteSpace(Request.City))
        {
            return;
        }

        try
        {
            var response = PixService.GeneratePayload(Request);
            var qr = QrCode.EncodeText(response.Payload, QrCode.Ecc.Medium);
            var svgText = qr.ToSvgString(4);

            svgText = svgText.Replace("<svg ", "<svg width=\"200\" height=\"200\" ");

            var svgBytes = System.Text.Encoding.UTF8.GetBytes(svgText);
            var base64Svg = Convert.ToBase64String(svgBytes);

            qrCodeBase64 = $"data:image/svg+xml;base64,{base64Svg}";
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao gerar QR Code: {ex.Message}");
        }
    }

    private async Task DownloadPlate()
    {
        await JS.InvokeVoidAsync("downloadElementAsImage", "placa-pix", $"PlacaPix_{Request.Name}.png");
    }
}