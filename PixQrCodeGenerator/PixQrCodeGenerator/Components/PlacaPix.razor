@page "/"
@using Net.Codecrete.QrCodeGenerator
@using PixQrCodeGenerator.Services
@inject PixService PixService
@inject IJSRuntime JS

<div class="container-fluid py-5">
    <div class="row">
        <!-- Formulário -->
        <div class="col-md-5 mb-4">
            <div class="card shadow-sm border-0 p-4">
                <h3 class="fw-bold mb-4">Configurar Placa</h3>
                <div class="mb-3">
                    <label class="form-label">Tipo de Chave</label>
                    <select class="form-select" @bind="tipoChave">
                        <option value="CPF">CPF/CNPJ</option>
                        <option value="EMAIL">E-mail</option>
                        <option value="TEL">Telefone</option>
                        <option value="ALEATORIA">Chave Aleatória</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Chave Pix</label>
                    <input class="form-control" placeholder="Digite sua chave" @bind="chave" @bind:event="oninput" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Nome do Recebedor</label>
                    <input class="form-control" placeholder="Ex: João Silva" @bind="nome" @bind:event="oninput" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Cidade</label>
                    <input class="form-control" placeholder="Ex: Sao Paulo" @bind="cidade" @bind:event="oninput" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Valor (Opcional)</label>
                    <input type="number" class="form-control" @bind="valor" @bind:event="oninput" />
                </div>
                <button class="btn btn-primary w-100 mt-3 py-2 fw-bold" @onclick="DownloadPlaca">
                    <i class="bi bi-download me-2"></i> Baixar Placa em PNG
                </button>
            </div>
        </div>

        <!-- Preview da Placa -->
        <div class="col-md-7 d-flex justify-content-center align-items-start">
            <div id="placa-pix" class="pix-card">
                <div class="pix-header">
                    <span>Pague com</span>
                    <img src="/pix-logo.png" alt="Logo Pix" class="pix-logo-img">
                </div>

                <div class="qr-container">
                    <div class="qr-code-white-box">
                        <img src="@qrCodeBase64" alt="QR Code" />
                    </div>
                </div>

                <div class="pix-footer">
                    <div class="info-group">
                        <span class="label">Chave Pix:</span>
                        <div class="pill">@chave</div>
                    </div>
                    <div class="info-group mt-3">
                        <span class="label">Nome:</span>
                        <div class="pill">@nome</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string tipoChave = "CPF";
    private string chave = "000.000.000-00";
    private string nome = "NOME DO RECEBEDOR";
    private string cidade = "CIDADE";
    private decimal? valor;
    private string qrCodeBase64 = "";

    protected override void OnInitialized() => GenerateQrCode();

    // Atualiza o QR Code sempre que um campo muda (Binding)
    protected override void OnParametersSet() => GenerateQrCode();

    private void GenerateQrCode()
    {
        try
        {
            // 1. Gera o Payload Pix usando o serviço
            string payload = PixService.GeneratePayload(chave, nome, cidade, valor);

            // 2. Cria o objeto QrCode
            var qr = QrCode.EncodeText(payload, QrCode.Ecc.Medium);

            // 3. Gera a string do SVG (o parâmetro 4 é a margem/border)
            string svgText = qr.ToSvgString(4);

            // 4. Converte o SVG para uma URL de dados Base64 para ser usada na tag <img>
            var svgBytes = System.Text.Encoding.UTF8.GetBytes(svgText);
            string base64Svg = Convert.ToBase64String(svgBytes);
        
            qrCodeBase64 = $"data:image/svg+xml;base64,{base64Svg}";
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao gerar QR Code: {ex.Message}");
        }
    }

    // Chamado no "oninput" para real-time preview
    protected override void OnAfterRender(bool firstRender)
    {
        GenerateQrCode();
        StateHasChanged();
    }

    private async Task DownloadPlaca()
    {
        await JS.InvokeVoidAsync("downloadElementAsImage", "placa-pix", $"PlacaPix_{nome}.png");
    }
}